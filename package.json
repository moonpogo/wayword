{
  "name": "wayword",
  "version": "1.0.0",
  "description": "Write. See what emerges.",
  "main": "mirror-engine.iife.js",
  "devDependencies": {
    "esbuild": "^0.28.0",
    "playwright": "^1.52.0"
  },
  "scripts": {
    "preview": "node scripts/preview-server.js",
    "build:mirror": "esbuild src/features/mirror/entry-iife.ts --bundle --format=iife --platform=browser --target=es2020 --global-name=WaywordMirror --outfile=mirror-engine.iife.js",
    "verify:mirror-bundle": "node scripts/verify-mirror-bundle.js",
    "verify:patterns-surface": "node scripts/verify-patterns-surface-strings.js",
    "eval:mirror": "node scripts/run-wayword-evaluation.js",
    "eval:patterns": "node scripts/run-patterns-evaluation.js",
    "postinstall": "playwright install chromium",
    "test:smoke": "node --test tests/browser-smoke.test.cjs",
    "test:logic": "node --test tests/app-logic.test.cjs tests/mirror-pipeline.test.cjs tests/patterns-aggregation.test.cjs",
    "test": "npm run test:logic",
    "verify:merge": "npm test && node --check script.js && npm run verify:mirror-bundle && npm run verify:patterns-surface",
    "test:regression": "npm test && node --check script.js && npm run test:smoke"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonpogo/wayword.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/moonpogo/wayword/issues"
  },
  "homepage": "https://github.com/moonpogo/wayword#readme"
}
