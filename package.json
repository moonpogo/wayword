{
  "name": "wayword",
  "version": "1.0.0",
  "description": "Write. See what emerges.",
  "main": "mirror-engine.iife.js",
  "devDependencies": {
    "esbuild": "^0.28.0"
  },
  "scripts": {
    "build:mirror": "esbuild src/features/mirror/entry-iife.ts --bundle --format=iife --platform=browser --target=es2020 --global-name=WaywordMirror --outfile=mirror-engine.iife.js",
    "verify:mirror-bundle": "node scripts/verify-mirror-bundle.js",
    "verify:patterns-surface": "node scripts/verify-patterns-surface-strings.js",
    "eval:mirror": "node scripts/run-wayword-evaluation.js",
    "eval:patterns": "node scripts/run-patterns-evaluation.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonpogo/wayword.git"
  },
